{
  "name": "pwrui",
  "version": "0.0.62",
  "description": "A library for building interactive React apps.",
  "author": "wipmate",
  "keywords": [
    "react",
    "ui"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc && cp node_modules/material-symbols/*.woff2 dist/ && tsx src/style/color.build.ts && cp src/style/color.build.scss dist/color.scss && cp src/style/symbols-dynamic.css dist/symbols-dynamic.css && sass --style compressed --no-source-map -I node_modules --quiet-deps src/style/main.scss dist/style.css && sass --style compressed --no-source-map -I node_modules --quiet-deps src/style/symbols-static.scss dist/symbols-static.css"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./color": {
      "default": "./dist/color.scss"
    },
    "./style.css": {
      "default": "./dist/style.css"
    },
    "./symbols-dynamic.css": {
      "default": "./dist/symbols-dynamic.css"
    },
    "./symbols-static.css": {
      "default": "./dist/symbols-static.css"
    },
    "./vite": {
      "import": "./dist/vite.js",
      "types": "./dist/vite.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pwrui/pwrui.git"
  },
  "peerDependencies": {
    "material-symbols": "^0.34.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@ktibow/material-color-utilities-nightly": "^0.3.11755825625476",
    "@types/node": "^24.3.0",
    "@types/opentype.js": "^1.3.10",
    "@types/react": "^19.0.7",
    "@types/subset-font": "^2.3.0",
    "material-symbols": "^0.34.0",
    "opentype.js": "^2.0.0",
    "sass": "^1.83.4",
    "subset-font": "^2.5.0",
    "tsx": "^4.20.4",
    "typescript": "^5.7.3",
    "vite": "^8.1.5"
  },
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85"
}